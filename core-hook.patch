diff --git a/src/server/game/Entities/Player/Player.cpp b/src/server/game/Entities/Player/Player.cpp
index 250a4d785..c942819b6 100644
--- a/src/server/game/Entities/Player/Player.cpp
+++ b/src/server/game/Entities/Player/Player.cpp
@@ -4692,6 +4692,10 @@ void Player::DurabilityPointsLoss(Item* item, int32 points)
     if (HasPreventDurabilityLossAura())
         return;

+    sScriptMgr->OnPlayerDurabilityPointsLoss(this, item, points);
+    if (points <= 0)
+        return;
+
     int32 pMaxDurability = item->GetUInt32Value(ITEM_FIELD_MAXDURABILITY);
@@ -6598,6 +6602,8 @@ void Player::_ApplyItemMods(Item* item, uint8 slot, bool apply)

     ApplyEnchantment(item, apply);

+    sScriptMgr->OnPlayerApplyItemMods(this, item, slot, apply);
+
     LOG_DEBUG("entities.player.items", "_ApplyItemMods complete.");
 }

diff --git a/src/server/game/Scripting/ScriptDefines/PlayerScript.cpp b/src/server/game/Scripting/ScriptDefines/PlayerScript.cpp
