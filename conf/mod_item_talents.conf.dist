[worldserver]

# Включение модуля "Пробуждение снаряжения" (таланты предметов).
# Default: 1 (включено)
ItemTalents.Enable = 1

# Сегменты убийств за 1..5-е очко таланта (через запятую).
# Кумулятивные пороги: 50, 200, 600, 1600, 4100 убийств.
ItemTalents.PointThresholds = "50,150,400,1000,2500"

# Максимальный ряд, доступный для выбора в этой версии.
# Ряды выше показываются в панели, но выбор запрещён ("скоро").
# Default: 4 (ряды 1-4; ряд 5 "Пробуждение" - фаза 2)
ItemTalents.MaxImplementedRow = 4

# Entry НПЦ мастеров оружия: рядом с ними разрешён выбор и сброс талантов,
# у них же появляется пункт госсипа "Пробудить снаряжение".
ItemTalents.MasterEntries = "2704,11865,11866,11867,11868,11869,11870,13084,16621,16773,17005"

# Радиус поиска мастера (ярды).
ItemTalents.MasterRange = 10

# Множитель опыта предмета за элитных мобов (задел, в v1 всегда 1).
ItemTalents.EliteMultiplier = 1

# Веса качества ролла перка: Обычный,Отличный,Совершенный (ровно 3 значения,
# нормировать до 100 не обязательно).
ItemTalents.QualityWeights = "70,25,5"

# Множители значения перка по качеству: Обычный,Отличный,Совершенный
# (ровно 3 значения; значение = ceil(база * множитель)).
ItemTalents.QualityMults = "1.0,1.25,1.5"

# Не начислять опыт предметам плейерботов (и не грузить их кэш).
# Default: 1 (боты вне системы)
ItemTalents.IgnoreBots = 1

# Ручные диапазоны entry для ряда 5 «Пробуждение» (стиль ahbot):
# формат "100-200,345841,400000-999999". Deny - предмету НИКОГДА не открыть
# ряд 5 (сильнее всех проверок); Allow - принудительно разрешить (минуя
# проверку базового качества). Пусто = автоматика: Quality=4 и предмет не
# является GA-копией (не встречается в item_upgrade_chain.next_entry).
ItemTalents.Row5.AllowEntryRanges = ""
ItemTalents.Row5.DenyEntryRanges = ""

#
#    Капы стакинга перков рядов 3-4 (суммарно по надетым предметам, PERKS.md).
#    Аурные эффекты (бег/лечение/физ. урон) дополнительно ограничены числом
#    рангов спеллов 108900-108914: фактический потолок 5% на эффект.
#    Физ. кап 3 (не 1 из PERKS.md): единственный щит может роллнуть
#    Совершенное качество = 3%, кап 1 обманывал бы тултип.
#

ItemTalents.Cap.MoveSpeedPct = 5
ItemTalents.Cap.HealTakenPct = 10
ItemTalents.Cap.PhysTakenPct = 3
ItemTalents.Cap.NemesisDmgPct = 15
ItemTalents.Cap.GoldPct = 20
ItemTalents.Cap.XpPct = 10

# Диапазоны spell id владельческих аур фамильяров (гача): бонус
# "Узы фамильяра" активен, пока на игроке есть аура из этих диапазонов.
ItemTalents.FamiliarAuraRanges = "103000-103099,104000-104099"

# Период обновления кэша spawnId немезид из character_nemesis (секунды).
# Обновляется, только если у кого-то онлайн выбран перк "Охотник на немезид".
ItemTalents.NemesisCacheRefreshSecs = 30

#
#    Звук пробуждённого предмета: играет владельцу при надевании и изредка
#    на убийствах. Только ПОЛНОСТЬЮ пробуждённое (выбраны все открытые
#    качеством ряды, не меньше MaxImplementedRow) ОРУЖИЕ В ОСНОВНОЙ РУКЕ.
#

# Пары "itemEntry:soundId" (SoundEntries.dbc) через запятую.
# Default: 873 "Посох Джордана" + HumanMaleOfficialNPCGreetings (5971).
ItemTalents.ItemSounds = "873:5971"

# Минимальный интервал между звуками на игрока (секунды).
ItemTalents.SoundCooldown = 30

# Шанс (в процентах) проиграть звук пробуждённого оружия при убийстве.
ItemTalents.SoundOnKillChance = 5

#
#    Ряд 5 "Пробуждение" (фаза 2): проки базовых эпиков.
#    Определения - item_talent_def (effect='PROC') + item_talent_procs,
#    спеллы 108000-108092 - spell_dbc (миграции mod_item_talents_subclass.sql
#    и mod_item_talents_proc_spells.sql, после применения нужен рестарт
#    worldserver).
#

# Существо Фамильяра-фантома (прок пула H "Фамильяр-фантом"): entry из
# creature_template. Дефолт 191090 - спиритовый фамильяр гачи (семья spirit).
ItemTalents.PhantomCreature = 191090
